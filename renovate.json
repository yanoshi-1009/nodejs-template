{
  "extends": [
    "config:recommended",
    ":automergeMinor",
    ":maintainLockFilesWeekly",
    ":skipStatusChecks"
  ],
  "timezone": "Asia/Tokyo",
  "schedule": "before 6am",
  "labels": [
    "renovate"
  ],
  "assignees": [
    "yanoshi-1009"
  ],
  "rangeStrategy": "bump",
  "lockFileMaintenance": {
    "automerge": true
  },
  "packageRules": [
    {
      "automerge": true,
      "matchPackageNames": [
        "/@cybozu/eslint-config/"
      ]
    },
    {
      "matchPackageNames": [
        "node",
        "pnpm"
      ],
      "enabled": false
    }
  ]
}
